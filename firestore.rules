rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - username: string (required, < 50 chars) - User's display name
    //   - avatar: string (required, < 500 chars) - URL to profile image
    //   - balance: number (required, >= 0) - DUCK balance
    //   - wins: number (required, >= 0) - Total wins
    //   - volume: number (required, >= 0) - Total volume
    //   - completedTasks: list of strings (required, < 100 items) - Task IDs
    //   - referralCode: string (optional, < 20 chars) - Referral code
    //   - referredBy: string (optional, < 50 chars) - UID of referrer
    //
    // Collection: games
    // Document ID: {gameId}
    // Fields:
    //   - id: string (required)
    //   - players: list of objects (required, < 50 items) - Player data
    //   - totalPot: number (required, >= 0) - Total pot
    //   - winner: map (optional) - Winner data
    //   - status: string (required, ['waiting', 'drawing', 'winner'])
    //   - createdAt: timestamp (required)
    // ===============================================================

    // Collection: transactions
    // Document ID: {transactionId}
    // Fields:
    //   - id: string (required)
    //   - uid: string (required)
    //   - amount: number (required, > 0)
    //   - type: string (required, ['deposit', 'withdrawal'])
    //   - status: string (required, ['pending', 'completed', 'failed'])
    //   - createdAt: timestamp (required)
    //
    // Collection: winners
    // Document ID: {winnerId}
    // Fields:
    //   - id: string (required)
    //   - gameId: string (required)
    //   - uid: string (required)
    //   - username: string (required)
    //   - avatar: string (required)
    //   - amount: number (required, >= 0)
    //   - winChance: number (required, >= 0)
    //   - createdAt: timestamp (required)
    //
    // Collection: stats
    // Document ID: winners
    // Fields:
    //   - lastWinner: map (required)
    //   - topWinner: map (required)
    //
    // Collection: tasks
    // Document ID: {taskId}
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - reward: number (required)
    //   - type: string (required, ['daily', 'partner', 'achievement', 'social'])
    //   - btn: string (optional)
    //   - link: string (optional)
    //   - completedCount: number (optional)
    //
    // Collection: promoCodes
    // Document ID: {codeId}
    // Fields:
    //   - code: string (required)
    //   - reward: number (required)
    //   - supply: number (required)
    //   - claimedBy: list (optional)
    //
    // Collection: referralLinks
    // Document ID: {linkId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - joins: number (optional)
    //   - ads: number (optional)
    //   - revenue: number (optional)
    //
    // Collection: withdrawalOffers
    // Document ID: {offerId}
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - minAmount: number (required)
    //   - maxAmount: number (required)
    //
    // Collection: analytics
    // Document ID: global
    // Fields:
    //   - totalUsers: number
    //   - joinedToday: number
    //   - activeToday: number
    //   - rewardAds: number
    //   - interstitials: number
    //   - totalSpins: number
    //   - pendingWithdrawals: number
    //   - totalRevenue: number
    //   - promosClaimed: number
    //   - tasksDone: number
    //   - totalBalance: number
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tgId in [6686954447, 1678112785, 5968063026])) ||
         (request.auth.token.email == "jahidproject8@gmail.com" && request.auth.token.email_verified == true));
    }

    function isAllowedAdmin(data) {
      return data.role == 'admin' && 
             (data.tgId in [6686954447, 1678112785, 5968063026] || 
              (request.auth.token.email == "jahidproject8@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'avatar', 'balance', 'wins', 'volume', 'completedTasks', 'role', 'tgId']) &&
             data.uid == request.auth.uid &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.avatar is string && data.avatar.size() < 500 &&
             data.balance is number && data.balance >= 0 &&
             data.wins is number && data.wins >= 0 &&
             data.volume is number && data.volume >= 0 &&
             data.completedTasks is list && data.completedTasks.size() < 100 &&
             data.role in ['user', 'admin'] &&
             (data.tgId == null || data.tgId is int) &&
             (data.referralsCount == null || data.referralsCount is int) &&
             (data.totalDeposited == null || data.totalDeposited is number) &&
             (data.totalWithdrawn == null || data.totalWithdrawn is number) &&
             (data.adsViewed == null || data.adsViewed is int) &&
             (data.spinsCount == null || data.spinsCount is int) &&
             (data.promosUsed == null || data.promosUsed is int) &&
             (data.shopPurchases == null || data.shopPurchases is list);
    }

    function isValidGame(data) {
      return data.keys().hasAll(['id', 'players', 'totalPot', 'status', 'createdAt']) &&
             data.id is string &&
             data.players is list && data.players.size() < 50 &&
             data.totalPot is number && data.totalPot >= 0 &&
             data.status in ['waiting', 'drawing', 'winner'] &&
             data.createdAt is timestamp;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['id', 'uid', 'amount', 'type', 'status', 'createdAt']) &&
             data.id is string &&
             data.uid == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.type in ['deposit', 'withdrawal'] &&
             data.status in ['pending', 'completed', 'failed'] &&
             data.createdAt is timestamp;
    }

    function isValidWinner(data) {
      return data.keys().hasAll(['id', 'gameId', 'uid', 'username', 'amount', 'createdAt']) &&
             data.id is string &&
             data.gameId is string &&
             data.uid is string &&
             data.username is string &&
             data.amount is number && data.amount >= 0 &&
             data.createdAt is timestamp;
    }

    function isValidStats(data) {
      return data.keys().hasAll(['lastWinner', 'topWinner']) &&
             data.lastWinner is map &&
             data.topWinner is map;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['id', 'title', 'reward', 'type']) &&
             data.id is string &&
             data.title is string && data.title.size() < 100 &&
             data.reward is number &&
             data.type in ['daily', 'partner', 'achievement', 'social'];
    }

    function isValidPromoCode(data) {
      return data.keys().hasAll(['code', 'reward', 'supply']) &&
             data.code is string && data.code.size() < 50 &&
             data.reward is number &&
             data.supply is int;
    }

    function isValidReferralLink(data) {
      return data.keys().hasAll(['id', 'name']) &&
             data.id is string &&
             data.name is string && data.name.size() < 100;
    }

    function isValidWithdrawalOffer(data) {
      return data.keys().hasAll(['id', 'title', 'minAmount', 'maxAmount']) &&
             data.id is string &&
             data.title is string &&
             data.minAmount is number &&
             data.maxAmount is number;
    }

    function isValidAnalytics(data) {
      return true; // Analytics are usually updated by server or admin
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /stats/{statId} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidStats(request.resource.data);
    }

    match /tasks/{taskId} {
      allow read: if true;
      allow write: if isAdmin() && isValidTask(request.resource.data);
    }

    match /promoCodes/{codeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidPromoCode(request.resource.data);
    }

    match /referralLinks/{linkId} {
      allow read: if true;
      allow write: if isAdmin() && isValidReferralLink(request.resource.data);
    }

    match /withdrawalOffers/{offerId} {
      allow read: if true;
      allow write: if isAdmin() && isValidWithdrawalOffer(request.resource.data);
    }

    match /analytics/{analyticsId} {
      allow read: if isAdmin();
      allow write: if isAdmin() && isValidAnalytics(request.resource.data);
    }

    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin() || (request.query.limit != null && request.query.limit <= 100);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                     (request.resource.data.role == 'user' || isAllowedAdmin(request.resource.data));
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && 
                       request.resource.data.uid == resource.data.uid && // UID immutable
                       request.resource.data.role == resource.data.role && // Role immutable
                       request.resource.data.balance == resource.data.balance && // Balance immutable
                       request.resource.data.puckBalance == resource.data.puckBalance) || // PuckBalance immutable
                       isAdmin();
    }

    match /games/{gameId} {
      allow read: if true; // Publicly readable for live game
      allow create, update: if isAuthenticated() && isValidGame(request.resource.data);
    }

    match /transactions/{transactionId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
      allow update: if isAdmin();
    }

    match /winners/{winnerId} {
      allow read: if true; // Publicly readable for leaderboard
      allow create: if isAuthenticated() && isValidWinner(request.resource.data);
      allow update: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
