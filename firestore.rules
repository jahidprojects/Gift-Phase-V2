rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - username: string (required, < 50 chars) - User's display name
    //   - avatar: string (required, < 500 chars) - URL to profile image
    //   - balance: number (required, >= 0) - TON balance
    //   - wins: number (required, >= 0) - Total wins
    //   - volume: number (required, >= 0) - Total volume
    //   - completedTasks: list of strings (required, < 100 items) - Task IDs
    //   - referralCode: string (optional, < 20 chars) - Referral code
    //   - referredBy: string (optional, < 50 chars) - UID of referrer
    //
    // Collection: games
    // Document ID: {gameId}
    // Fields:
    //   - id: string (required)
    //   - players: list of objects (required, < 50 items) - Player data
    //   - totalPot: number (required, >= 0) - Total pot
    //   - winner: map (optional) - Winner data
    //   - status: string (required, ['waiting', 'drawing', 'winner'])
    //   - createdAt: timestamp (required)
    // ===============================================================

    // Collection: transactions
    // Document ID: {transactionId}
    // Fields:
    //   - id: string (required)
    //   - uid: string (required)
    //   - amount: number (required, > 0)
    //   - type: string (required, ['deposit', 'withdrawal'])
    //   - status: string (required, ['pending', 'completed', 'failed'])
    //   - createdAt: timestamp (required)
    //
    // Collection: winners
    // Document ID: {winnerId}
    // Fields:
    //   - id: string (required)
    //   - gameId: string (required)
    //   - uid: string (required)
    //   - username: string (required)
    //   - avatar: string (required)
    //   - amount: number (required, >= 0)
    //   - winChance: number (required, >= 0)
    //   - createdAt: timestamp (required)
    //
    // Collection: stats
    // Document ID: winners
    // Fields:
    //   - lastWinner: map (required)
    //   - topWinner: map (required)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tgId in [6686954447, 1678112785, 5968063026])) ||
         (request.auth.token.email == "jahidproject8@gmail.com" && request.auth.token.email_verified == true));
    }

    function isAllowedAdmin(data) {
      return data.role == 'admin' && 
             (data.tgId in [6686954447, 1678112785, 5968063026] || 
              (request.auth.token.email == "jahidproject8@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'avatar', 'balance', 'wins', 'volume', 'completedTasks', 'role', 'tgId']) &&
             data.uid == request.auth.uid &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.avatar is string && data.avatar.size() < 500 &&
             data.balance is number && data.balance >= 0 &&
             data.wins is number && data.wins >= 0 &&
             data.volume is number && data.volume >= 0 &&
             data.completedTasks is list && data.completedTasks.size() < 100 &&
             data.role in ['user', 'admin'] &&
             (data.tgId == null || data.tgId is int);
    }

    function isValidGame(data) {
      return data.keys().hasAll(['id', 'players', 'totalPot', 'status', 'createdAt']) &&
             data.id is string &&
             data.players is list && data.players.size() < 50 &&
             data.totalPot is number && data.totalPot >= 0 &&
             data.status in ['waiting', 'drawing', 'winner'] &&
             data.createdAt is timestamp;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['id', 'uid', 'amount', 'type', 'status', 'createdAt']) &&
             data.id is string &&
             data.uid == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.type in ['deposit', 'withdrawal'] &&
             data.status in ['pending', 'completed', 'failed'] &&
             data.createdAt is timestamp;
    }

    function isValidWinner(data) {
      return data.keys().hasAll(['id', 'gameId', 'uid', 'username', 'amount', 'createdAt']) &&
             data.id is string &&
             data.gameId is string &&
             data.uid is string &&
             data.username is string &&
             data.amount is number && data.amount >= 0 &&
             data.createdAt is timestamp;
    }

    function isValidStats(data) {
      return data.keys().hasAll(['lastWinner', 'topWinner']) &&
             data.lastWinner is map &&
             data.topWinner is map;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /stats/{statId} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidStats(request.resource.data);
    }

    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin() || (request.query.limit != null && request.query.limit <= 100);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                     (request.resource.data.role == 'user' || isAllowedAdmin(request.resource.data));
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && 
                       request.resource.data.uid == resource.data.uid && // UID immutable
                       request.resource.data.role == resource.data.role) || // Role immutable for users
                       isAdmin();
    }

    match /games/{gameId} {
      allow read: if true; // Publicly readable for live game
      allow create, update: if isAdmin(); // Only admins can manage game state
    }

    match /transactions/{transactionId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
      allow update: if isAdmin();
    }

    match /winners/{winnerId} {
      allow read: if true; // Publicly readable for leaderboard
      allow create: if isAuthenticated() && isValidWinner(request.resource.data);
      allow update: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
